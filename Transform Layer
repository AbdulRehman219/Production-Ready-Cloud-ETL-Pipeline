import pandas as pd

def transform_data(df):
    print("Transforming data...")

    df["time"] = pd.to_datetime(df["time"])
    df["usd_rate"] = df["usd_rate"].str.replace(",", "").astype(float)
    df["gbp_rate"] = df["gbp_rate"].str.replace(",", "").astype(float)

    print("Transformation complete")
    return df
